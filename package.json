{
  "name": "testray-yaml-extension",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.86.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "scripts": {
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test:types": "tsc -p ./",
    "test:watch": "jest --watch",
    "package": "vsce package",
    "vscode:prepublish": "npm run esbuild-base -- --minify"
  },
  "dependencies": {
    "glob": "10.3.10"
  },
  "devDependencies": {
    "@swc/core": "^1.3.107",
    "@swc/jest": "^0.2.34",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.2",
    "jest": "^29.7.0",
    "typescript": "^5.3.3"
  },
  "displayName": "TestRay YAML Extension",
  "description": "TestRay-aware YAML tooling for VS Code/Cursor: go to definition, references, rename, diagnostics, completion, hover, symbols, and inlay hints.",
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "testray",
    "yaml",
    "automation",
    "testing",
    "go to definition",
    "references",
    "rename",
    "diagnostics",
    "hover",
    "inlay hints"
  ],
  "license": "MIT",
  "publisher": "FilipsMudulis",
  "author": {
    "name": "Filips Mudulis",
    "email": "filips.mudulis@testdevlab.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FilipsMudulis/testray-yaml-extension"
  }
}
